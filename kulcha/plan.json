  ],
  "js_features": [
    {
      "name": "Mobile Nav Toggle",
      "selector": ".nav-toggle",
      "action": "toggle nav-open on .nav-links",
      "guard": "null-check"
    },
    {
      "name": "Smooth Scroll",
      "selector": ".nav-link",
      "action": "scrollIntoView smooth",
      "guard": "null-check"
    },
    {
      "name": "Scroll Reveal",
      "selector": ".reveal",
      "action": "IntersectionObserver adds visible",
      "guard": "feature detect"
    },
    {
      "name": "Sticky Nav",
      "selector": "window",
      "action": "add scrolled to #nav on scrollY>50",
      "guard": "none"
    },
    {
      "name": "Gallery Lightbox",
      "selector": ".gallery-item",
      "action": "open lightbox on click",
      "guard": "null-check"
    },
    {
      "name": "Menu Filter",
      "selector": ".filter-button",
      "action": "filter menu items by type",
      "guard": "null-check"
    },
    {
      "name": "Order Form Submit",
      "selector": ".order-submit",
      "action": "validate and submit form",
      "guard": "null-check"
    }
  ],
  "google_fonts_url": "https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Open+Sans:wght@400;600;700&display=swap"
}