  "js_features": [
    {
      "name": "Mobile Nav Toggle",
      "selector": ".nav-toggle",
      "action": "toggle nav-open on .nav-links",
      "guard": "null-check"
    },
    {
      "name": "Smooth Scroll",
      "selector": ".nav-link",
      "action": "scrollIntoView smooth",
      "guard": "null-check"
    },
    {
      "name": "Scroll Reveal",
      "selector": ".reveal",
      "action": "IntersectionObserver adds visible",
      "guard": "feature detect"
    },
    {
      "name": "Sticky Nav",
      "selector": "#nav",
      "action": "add scrolled to #nav on scrollY>50",
      "guard": "none"
    },
    {
      "name": "Product Quick View",
      "selector": ".product-card",
      "action": "show modal on click",
      "guard": "null-check"
    },
    {
      "name": "Cart Counter",
      "selector": ".cart-icon",
      "action": "update count on product add",
      "guard": "null-check"
    }
  ],
  "google_fonts_url": "https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Open+Sans:wght@400;600;700&display=swap"
}