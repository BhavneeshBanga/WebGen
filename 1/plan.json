  "js_features": [
    {
      "name": "Mobile Nav Toggle",
      "selector": ".nav-toggle",
      "action": "toggle class 'nav-open' on .nav-links",
      "guard": "null-check before addEventListener"
    },
    {
      "name": "Smooth Scroll",
      "selector": ".nav-link",
      "action": "preventDefault, scrollIntoView({behavior:'smooth'})",
      "guard": "null-check"
    },
    {
      "name": "Scroll Reveal",
      "selector": ".reveal",
      "action": "IntersectionObserver adds class 'visible' when 20% in view",
      "guard": "check IntersectionObserver support"
    },
    {
      "name": "Sticky Nav Shadow",
      "selector": "window scroll",
      "action": "add class 'scrolled' to nav when scrollY > 50",
      "guard": "none needed"
    },
    {
      "name": "Product Filter",
      "selector": ".product-category",
      "action": "filter products by category when clicked",
      "guard": "check if products exist"
    },
    {
      "name": "Cart Counter",
      "selector": ".add-to-cart",
      "action": "increment cart count and update UI",
      "guard": "initialize cart state"
    },
    {
      "name": "Special Filter",
      "selector": ".special-item",
      "action": "highlight special items when hovered",
      "guard": "check if specials exist"
    },
    {
      "name": "Delivery Hours",
      "selector": ".delivery-hours",
      "action": "display current delivery status",
      "guard": "check delivery data"
    }
  ],
  "google_fonts_url": "https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Open+Sans:wght@400;600;700&display=swap"
}