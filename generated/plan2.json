{
  "title": "Kirana Store Website",
  "theme": {
    "mood": "earthy",
    "primary": "#8B4513",
    "secondary": "#228B22",
    "accent": "#FFD700",
    "background": "#FFF8DC",
    "surface": "#F5F5DC",
    "text": "#3E2723",
    "text_muted": "#666666",
    "font_heading": "Roboto",
    "font_body": "Open Sans",
    "border_radius": "8px"
