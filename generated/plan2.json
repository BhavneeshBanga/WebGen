        "section heading",
        "about text",
        "about image"
      ],
      "needs_image": true,
      "image_query": "traditional Indian kirana store with shelves full of spices and packaged goods"
    },
    {
      "id": "products",
      "tag": "section",
      "name": "Products",
      "classes": [
        "products",
        "products-container",
        "products-grid",
        "product-card",
        "product-img",
        "product-content",
        "product-title",
        "product-price",
        "product-desc"
      ],
      "elements": [
        "section heading",
        "product cards",
        "product images",
        "product titles",
        "product prices",
        "product descriptions"
      ],
      "needs_image": true,
      "image_query": "arranged display of Indian spices, lentils, rice, and cooking oils on wooden shelves"
    },
    {
      "id": "featured",
      "tag": "section",
      "name": "Featured Products",
      "classes": [
