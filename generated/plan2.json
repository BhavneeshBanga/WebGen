        "featured-content",
        "featured-title",
        "featured-grid",
        "featured-card",
        "featured-img",
        "featured-info",
        "featured-price",
        "featured-desc"
      ],
      "elements": [
        "section heading",
        "featured product cards",
        "product images",
        "product titles",
        "product prices",
        "product descriptions"
      ],
      "needs_image": true,
      "image_query": "popular Indian grocery items like atta, sugar, tea, and biscuits in attractive display"
    },
    {
      "id": "contact",
      "tag": "section",
      "name": "Contact",
      "classes": [
        "contact",
        "contact-container",
        "contact-content",
        "contact-title",
        "contact-info",
        "contact-map",
        "contact-form",
        "form-group",
        "form-label",
        "form-input",
        "form-submit"
      ],
      "elements": [
        "section heading",
        "contact information",
        "map",
        "contact form",
        "form fields",
        "submit button"
      ],
      "needs_image": false,
      "image_query": ""
    }
  ],
  "image_queries": [
    {
      "key": "hero_bg",
      "query": "colorful Indian vegetable market stall with fresh produce and baskets",
      "used_in": "hero section background"
    },
    {
      "key": "about_img",
      "query": "traditional Indian kirana store with shelves full of spices and packaged goods",
      "used_in": "about section"
    },
    {
      "key": "products_img",
      "query": "arranged display of Indian spices, lentils, rice, and cooking oils on wooden shelves",
      "used_in": "products section"
    },
    {
      "key": "featured_img",
      "query": "popular Indian grocery items like atta, sugar, tea, and biscuits in attractive display",
      "used_in": "featured products section"
    }
  ],
  "all_classes": [
    "navbar",
    "nav-container",
    "nav-logo",
    "nav-links",
    "nav-link",
    "nav-toggle",
    "nav-toggle-bar",
    "hero",
    "hero-bg",
    "hero-content",
    "hero-title",
    "hero-subtitle",
    "hero-cta",
    "about",
    "about-container",
    "about-content",
    "about-title",
    "about-text",
    "about-img",
    "products",
    "products-container",
    "products-grid",
    "product-card",
    "product-img",
    "product-content",
    "product-title",
    "product-price",
    "product-desc",
    "featured",
    "featured-container",
    "featured-content",
    "featured-title",
    "featured-grid",
    "featured-card",
    "featured-img",
    "featured-info",
    "featured-price",
    "featured-desc",
    "contact",
    "contact-container",
    "contact-content",
    "contact-title",
    "contact-info",
    "contact-map",
    "contact-form",
    "form-group",
    "form-label",
    "form-input",
    "form-submit",
    "reveal"
  ],
  "all_ids": [
    "nav",
    "hero",
    "about",
    "products",
    "featured",
    "contact"
  ],
  "js_features": [
    {
      "name": "Mobile Nav Toggle",
      "selector": ".nav-toggle",
      "action": "toggle class 'nav-open' on .nav-links",
      "guard": "null-check before addEventListener"
    },
    {
      "name": "Smooth Scroll",
      "selector": ".nav-link",
      "action": "preventDefault, scrollIntoView({behavior:'smooth'})",
      "guard": "null-check"
    },
    {
      "name": "Scroll Reveal",
      "selector": ".reveal",
      "action": "IntersectionObserver adds class 'visible' when 20% in view",
      "guard": "check IntersectionObserver support"
    },
    {
      "name": "Sticky Nav Shadow",
      "selector": "window scroll",
      "action": "add class 'scrolled' to nav when scrollY > 50",
      "guard": "none needed"
    },
    {
      "name": "Form Validation",
      "selector": ".contact-form",
      "action": "validate email and phone fields on submit",
      "guard": "check form elements exist"
    },
    {
      "name": "Lazy Load Images",
      "selector": "img[data-src]",
      "action": "load images when in viewport",
      "guard": "check image support"
    }
  ],
  "google_fonts_url": "https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&family=Open+Sans:wght@400;600&display=swap"
}