  "js_features": [
    {
      "name": "Mobile Nav Toggle",
      "selector": ".nav-toggle",
      "action": "toggle class 'nav-open' on .nav-links",
      "guard": "null-check before addEventListener"
    },
    {
      "name": "Smooth Scroll",
      "selector": ".nav-link",
      "action": "preventDefault, scrollIntoView({behavior:'smooth'})",
      "guard": "null-check"
    },
    {
      "name": "Scroll Reveal",
      "selector": ".product-card",
      "action": "IntersectionObserver adds class 'visible' when 20% in view",
      "guard": "check IntersectionObserver support"
    },
    {
      "name": "Sticky Nav Shadow",
      "selector": "window scroll",
      "action": "add class 'scrolled' to nav when scrollY > 50",
      "guard": "none needed"
    },
    {
      "name": "Cart Counter",
      "selector": ".cart-item",
      "action": "increment cart counter and update UI",
      "guard": "check if cart exists in localStorage"
    },
    {
      "name": "Product Filter",
      "selector": ".filter-btn",
      "action": "filter products based on selected category",
      "guard": "check if products loaded"
    },
    {
      "name": "Search Functionality",
      "selector": ".search-input",
      "action": "filter products as user types",
      "guard": "debounce search input"
    },
    {
      "name": "Offer Countdown",
      "selector": ".offer-card",
      "action": "add countdown timer for expiring offers",
      "guard": "check if offer has expiry date"
    },
    {
      "name": "Delivery Zone Check",
      "selector": ".delivery-info",
      "action": "check if user is within delivery zone",
      "guard": "check user location"
    }
  ],
  "google_fonts_url": "https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&family=Open+Sans:wght@400;600;700&display=swap"
}